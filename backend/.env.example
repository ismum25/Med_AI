APP_NAME=HealthcareAPI
APP_ENV=development
SECRET_KEY=your-secret-key-min-32-chars-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256

DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/healthcare
SYNC_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/healthcare

REDIS_URL=redis://:redis@localhost:6379/0
CELERY_BROKER_URL=redis://:redis@localhost:6379/1
CELERY_RESULT_BACKEND=redis://:redis@localhost:6379/2

STORAGE_BACKEND=minio
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=healthcare-files
MINIO_SECURE=false

AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_S3_BUCKET=healthcare-files
AWS_REGION=us-east-1

ANTHROPIC_API_KEY=your-anthropic-api-key
LLM_MODEL=claude-haiku-4-5-20251001

SENDGRID_API_KEY=your-sendgrid-api-key
FROM_EMAIL=noreply@healthcare.com

ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

LOG_LEVEL=INFO

# FastAPI CLI / uvicorn listen port (override: fastapi dev --port …)
PORT=8001

# Docker Compose: docker-compose.yml sets DATABASE_URL, REDIS_URL, Celery, and
# MINIO_ENDPOINT to service hostnames (postgres, redis, minio) so localhost
# values here still work on the host for local runs.
